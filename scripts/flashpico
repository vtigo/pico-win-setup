#!/usr/bin/env bash
# flashpico — copy a .uf2 to a Raspberry Pi Pico in BOOTSEL mode
# usage: flashpico firmware.uf2
set -euo pipefail

UF2="${1:-}"
if [ -z "$UF2" ]; then
  echo "usage: flashpico firmware.uf2" >&2
  exit 2
fi
if [ ! -f "$UF2" ]; then
  echo "error: file not found: $UF2" >&2
  exit 2
fi

# Find the block device whose model is RP2 (the Pico in BOOTSEL mode).
PART=$(lsblk -o NAME,MODEL -nr | awk '$2=="RP2"{print "/dev/"$1"1"; exit}')
if [ -z "$PART" ]; then
  echo "No Pico in BOOTSEL mode found." >&2
  echo "Did you run 'usbipd attach --wsl --busid <id>' on Windows first?" >&2
  exit 1
fi

echo "Found Pico at $PART"
sudo mkdir -p /mnt/pico
sudo mount "$PART" /mnt/pico
sudo cp "$UF2" /mnt/pico/
sync
# The Pico usually reboots and drops the mount on its own; umount defensively.
sudo umount /mnt/pico 2>/dev/null || true
echo "Flashed $(basename "$UF2") — Pico is rebooting."
